{
  "manifest_version": 3,
  "name": "Cosmic Ventures",
  "version": "2.0.0",
  "description": "Space idle clicker — runs entirely in your toolbar. No tabs needed.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Cosmic Ventures"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"]
}
